<Window x:Class="FinalDemoExam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список товаров" Height="760" Width="1220" MinHeight="650" MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        Icon="/Image/Icon.ico">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Image Source="/Image/Icon.png" Height="42" Stretch="Uniform" Margin="0,0,12,0"/>
                    <TextBlock Text="Список товаров" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="Пользователь: " FontWeight="Bold" FontFamily="Times New Roman"/>
            <TextBlock x:Name="txtUserFullName" Text="" FontWeight="Bold" Foreground="#7FFF00"/>
            <Button x:Name="btnLogout" Content="Выйти" Background="#00FA9A" Click="btnLogout_Click" Margin="20,0,0,0"/>
        </StackPanel>
            </DockPanel>
        </Border>

        <StackPanel x:Name="filtersPanel" Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
            <TextBlock Text="Поиск:" VerticalAlignment="Center"/>
            <TextBox x:Name="txtSearch" Width="200" Margin="5,0" TextChanged="txtSearch_TextChanged"/>
            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <ComboBox x:Name="cmbSort" Width="150" Margin="5,0" SelectionChanged="cmbSort_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="Цена по возрастанию"/>
                <ComboBoxItem Content="Цена по убыванию"/>
                <ComboBoxItem Content="Количество по возрастанию"/>
                <ComboBoxItem Content="Количество по убыванию"/>
            </ComboBox>
            <TextBlock Text="Фильтр по скидке:" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <ComboBox x:Name="cmbDiscountFilter" Width="150" Margin="5,0" SelectionChanged="cmbDiscountFilter_SelectionChanged">
                <ComboBoxItem Content="Все диапазоны" IsSelected="True"/>
                <ComboBoxItem Content="0-12,99%"/>
                <ComboBoxItem Content="13-16,99%"/>
                <ComboBoxItem Content="17% и более"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="btnAdd" Content="Добавить товар" Background="#00FA9A" Click="btnAdd_Click" Visibility="Collapsed"/>
            <Button x:Name="btnOrders" Content="Заказы" Background="#7FFF00" Click="btnOrders_Click" Visibility="Collapsed"/>
        </StackPanel>

        <ListView x:Name="lvProducts" Grid.Row="3" Margin="0,8,0,0" MouseDoubleClick="lvProducts_MouseDoubleClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="{Binding RowBackground}"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding RowBackground}" BorderBrush="LightGray" BorderThickness="1" Padding="5" Margin="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левая часть: Фото -->
                            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="2" Padding="2">
                                <Image Height="120" Width="120" Stretch="Uniform" Margin="5" Source="{Binding DisplayPhotoPath}"/>
                            </Border>

                            <!-- Центральная часть: Данные товара -->
                            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="2" Padding="10">
                                <StackPanel VerticalAlignment="Center">
                                    <!-- Категория | Наименование (в одну строку) -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Categories.name}" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text=" | " FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding name}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Описание -->
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="Описание: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding description}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Производитель -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Производитель: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Manufacturers.name}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Поставщик -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Поставщик: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Suppliers.name}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Цена -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding PriceText}"/>
                                    </StackPanel>

                                    <!-- Единица измерения -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Единица измерения: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Units.name}"/>
                                    </StackPanel>

                                    <!-- Количество на складе -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Количество на складе: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding stock_quantity}"/>
                                        <TextBlock Text=" "/>
                                        <TextBlock Text="{Binding Units.name}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Правая часть: Скидка -->
                            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="2" Padding="5" VerticalAlignment="Stretch">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Скидка:" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DiscountText}" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>