<Window x:Class="FinalDemoExam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список товаров" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        Icon="/Image/Icon.ico">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="Пользователь: " FontWeight="Bold" FontFamily="Times New Roman"/>
            <TextBlock x:Name="txtUserFullName" Text="" FontWeight="Bold" Foreground="#7FFF00"/>
            <Button x:Name="btnLogout" Content="Выйти" Background="#00FA9A" Click="btnLogout_Click" Margin="20,0,0,0"/>
        </StackPanel>

        <StackPanel x:Name="filtersPanel" Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Поиск:" VerticalAlignment="Center"/>
            <TextBox x:Name="txtSearch" Width="200" Margin="5,0" TextChanged="txtSearch_TextChanged"/>
            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <ComboBox x:Name="cmbSort" Width="150" Margin="5,0" SelectionChanged="cmbSort_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="Цена по возрастанию"/>
                <ComboBoxItem Content="Цена по убыванию"/>
                <ComboBoxItem Content="Количество по возрастанию"/>
                <ComboBoxItem Content="Количество по убыванию"/>
            </ComboBox>
            <TextBlock Text="Фильтр по скидке:" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <ComboBox x:Name="cmbDiscountFilter" Width="150" Margin="5,0" SelectionChanged="cmbDiscountFilter_SelectionChanged">
                <ComboBoxItem Content="Все диапазоны" IsSelected="True"/>
                <ComboBoxItem Content="0-12,99%"/>
                <ComboBoxItem Content="13-16,99%"/>
                <ComboBoxItem Content="17% и более"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="btnAdd" Content="Добавить товар" Background="#00FA9A" Click="btnAdd_Click" Visibility="Collapsed"/>
            <Button x:Name="btnOrders" Content="Заказы" Background="#7FFF00" Click="btnOrders_Click" Visibility="Collapsed"/>
        </StackPanel>

        <ListView x:Name="lvProducts" Grid.Row="3" Margin="0,10,0,0" MouseDoubleClick="lvProducts_MouseDoubleClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="{Binding RowBackground}"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding RowBackground}" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Height="100" Width="100" Stretch="Uniform" Margin="5" Source="{Binding DisplayPhotoPath}"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5">
                                <TextBlock Text="{Binding name}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Categories.name}" Foreground="Gray"/>
                                <TextBlock Text="{Binding description}" TextWrapping="Wrap"/>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Производитель: {0}">
                                            <Binding Path="Manufacturers.name"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Поставщик: {0}">
                                            <Binding Path="Suppliers.name"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="5">
                                <TextBlock Text="{Binding PriceText}" FontWeight="Bold" TextAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="5">
                                <TextBlock Text="Цена со скидкой:" FontSize="11" Foreground="Gray"/>
                                <TextBlock Text="{Binding FinalPriceText}" FontWeight="Bold" FontSize="16" Foreground="Black"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="5">
                                <TextBlock Text="Скидка:" FontSize="11" Foreground="Gray"/>
                                <TextBlock FontWeight="Bold" FontSize="16">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}%">
                                            <Binding Path="discount"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="5">
                                <TextBlock Text="На складе:" FontSize="11" Foreground="Gray"/>
                                <TextBlock FontWeight="Bold" FontSize="16">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="stock_quantity"/>
                                            <Binding Path="Units.name"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Column="6" Text="Нет в наличии" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontWeight="Bold" Foreground="White" Background="Gray" Padding="10,5">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding stock_quantity}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>