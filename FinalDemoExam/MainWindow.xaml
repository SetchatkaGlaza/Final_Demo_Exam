<Window x:Class="FinalDemoExam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список товаров" Height="1000" Width="900" Icon="/Image/Icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
            <Image Source="/Image/Icon.png" Height="45" Stretch="Uniform" Margin="5"/>
            <TextBlock Text="Список товаров" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
            <TextBlock Text="Пользователь: "/>
            <TextBlock Text="" x:Name="txtUserFullName" FontWeight="Bold"/>
            <Button Content="Выйти" x:Name="btnExit" Margin="10,0,10,0" Background="#00FA9A" Foreground="white" FontWeight="Bold" Click="btnExit_Click"/>
        </StackPanel>
        <StackPanel Grid.Row="1" HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center" x:Name="filterPanel">
            <TextBlock Text="Поиск: "/>
            <TextBox x:Name="txtSearch" Width="150" TextChanged="FilterChanged"/>
            <TextBlock Text="Сортировка: " Margin="5,0,0,0"/>
            <ComboBox x:Name="cmbSort" Width="120" SelectionChanged="FilterChanged">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="Цена по возрастанию"/>
                <ComboBoxItem Content="Цена по убыванию"/>
                <ComboBoxItem Content="Количество по возрастанию"/>
                <ComboBoxItem Content="Количество по убыванию"/>
            </ComboBox>
            <TextBlock Text="Фильтрация: " Margin="5,0,0,0"/>
            <ComboBox x:Name="cmbFilter" Width="120" SelectionChanged="FilterChanged">
                <ComboBoxItem Content="Без фильтрации" IsSelected="True"/>
                <ComboBoxItem Content="0-12,99%"/>
                <ComboBoxItem Content="13-16,99%"/>
                <ComboBoxItem Content="17% и более"/>
            </ComboBox>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button x:Name="btnAdd" Content="Добавить товар" Background="#00FA9A" Foreground="white" FontWeight="Bold" Visibility="Collapsed" Margin="5" Click="btnAdd_Click"/>
            <Button x:Name="btnOrders" Content="Заказы" Background="#00FA9A" Foreground="white" FontWeight="Bold" Visibility="Collapsed" Margin="5" Click="btnOrders_Click"/>
        </StackPanel>
        <ListView Grid.Row="3" x:Name="lvProducts" MouseDoubleClick="lvProducts_MouseDoubleClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="{Binding RowBackground}"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding RowBackground}" BorderBrush="LightGray" BorderThickness="1" Padding="5" Margin="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="2" Padding="2">
                                <Image Height="120" Width="120" Stretch="Uniform" Margin="5" Source="{Binding DisplayPhotoPath}"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="gray" BorderThickness="1" Margin="2" Padding="10">
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Categories.name}" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text=" | " FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding name}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Описание: " />
                                        <TextBlock Text="{Binding description}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Производитель: "/>
                                        <TextBlock Text="{Binding Manufacturers.name}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Поставщик: "/>
                                        <TextBlock Text="{Binding Suppliers.name}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding PriceText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Единица измерения: "/>
                                        <TextBlock Text="{Binding Units.name}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Количество на складе: "/>
                                        <TextBlock Text="{Binding stock_quantity}"/>
                                        <TextBlock Text=" "/>
                                        <TextBlock Text="{Binding Units.name}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="2" Padding="5" VerticalAlignment="Stretch">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Скидка: " FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DiscountText}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>