<Window x:Class="FinalDemoExam.ListOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cписок заказов" Height="450" Width="800" Icon="/Image/Icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Список заказов" FontSize="16" FontWeight="Bold"/>
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
            <TextBlock Text="Пользователь: "/>
            <TextBlock Text="" x:Name="txtUserFullName" FontWeight="Bold"/>
            <Button Content="Выйти" x:Name="btnExit" Margin="10,0,10,0" Background="#00FA9A" Foreground="white" FontWeight="Bold" Click="btnExit_Click"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button Content="Добавить заказ" x:Name="btnAddOrders" Margin="10,0,10,0" Background="#00FA9A" Foreground="white" FontWeight="Bold" Click="btnAddOrders_Click"/>
        </StackPanel>
        <ListView Grid.Row="2" x:Name="lvOrders" MouseDoubleClick="lvOrders_MouseDoubleClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="2" Padding="5" Margin="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="2" Padding="5" VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding id}" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{Binding OrderStatuses.name}"/>
                                    <TextBlock Text="{Binding PickupPoints.address}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding order_date, StringFormat={}{0:dd.MM.yyyy}}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="2" Margin="2" Padding="5" VerticalAlignment="Stretch">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding delivery_date, StringFormat={}{0:dd.MM.yyyy}}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
