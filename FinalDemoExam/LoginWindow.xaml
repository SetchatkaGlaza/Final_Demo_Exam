<Window x:Class="FinalDemoExam.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="540" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        Icon="/Image/icon.ico">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="95"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image Source="/Image/Icon.png" Height="70" Stretch="Uniform"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="26" HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
            <StackPanel>
                <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                <TextBlock Text="Логин:"/>
                <TextBox x:Name="txtLogin"/>
                <TextBlock Text="Пароль:" Margin="0,10,0,0"/>
                <PasswordBox x:Name="txtPassword"/>
                <Button x:Name="btnLogin" Content="Войти" Width="190" Margin="0,22,0,0" Background="#00FA9A" Click="btnLogin_Click"/>
                <Button x:Name="btnGuest" Content="Войти как гость" Width="190" Background="#7FFF00" Click="btnGuest_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>