<Window x:Class="FinalDemoExam.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="550" Width="500" Icon="/Image/Icon.ico">
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Image/Icon.png" Height="70" Stretch="Uniform"/>
                <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Логин: "/>
                <TextBox x:Name="txtLogin" Margin="0,0,0,5"/>
                <TextBlock Text="Пароль:"/>
                <PasswordBox x:Name="txtPassword" Margin="0,0,0,5"/>
                <Button Content="Войти" x:Name="btnLogin" Background="#00FA9A" Foreground="white" FontWeight="Bold" Width="120" Margin="0,0,0,5" Click="btnLogin_Click"/>
                <Button Content="Войти как гость" x:Name="BtnGuest" Background="#00FA9A" Foreground="white" FontWeight="Bold" Width="120" Click="BtnGuest_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>