<Window x:Class="FinalDemoExam.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        Icon="/Image/icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image Source="/Image/Icon.png" Height="60" Stretch="Uniform"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Логин:"/>
            <TextBox x:Name="txtLogin" Height="30"/>
            <TextBlock Text="Пароль:" Margin="0,10,0,0"/>
            <PasswordBox x:Name="txtPassword" Height="30"/>
            <Button x:Name="btnLogin" Content="Войти" Width="150" Margin="0,20,0,0" Background="#00FA9A" Click="btnLogin_Click"/>
            <Button x:Name="btnGuest" Content="Войти как гость" Width="150" Background="#7FFF00" Click="btnGuest_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="© 2026 Все права защищены" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Foreground="Gray"/>
    </Grid>
</Window>