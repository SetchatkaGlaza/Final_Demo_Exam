<Window x:Class="FinalDemoExam.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalDemoExam"
        mc:Ignorable="d"
        Title="Добавление/редактирование товара" Height="750" Width="500" 
        Icon="/Image/Icon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавление/редактирование товара" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel>
                    <TextBlock Text="Артикул:"/>
                    <TextBox x:Name="txtArticle" IsEnabled="False"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Наименование:"/>
                    <TextBox x:Name="txtName"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Категория:"/>
                    <ComboBox x:Name="cmbCategory" DisplayMemberPath="name" SelectedValuePath="id"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Описание:"/>
                    <TextBox x:Name="txtDescription" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Производитель:"/>
                    <TextBox x:Name="txtManufacturer"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Поставщик:"/>
                    <ComboBox x:Name="cmbSupplier" DisplayMemberPath="name" SelectedValuePath="id"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Цена:"/>
                    <TextBox x:Name="txtPrice"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Единица измерения:"/>
                    <ComboBox x:Name="cmbUnit" DisplayMemberPath="name" SelectedValuePath="id"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Количество на складе:"/>
                    <TextBox x:Name="txtStock"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Скидка (%):"/>
                    <TextBox x:Name="txtDiscount"/>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Фото товара:"/>
                    <Button x:Name="btnBrowse" Content="Выбрать фото" Background="#00FA9A" Foreground="white" FontWeight="Bold" Click="btnBrowse_Click" Width="150"/>
                    <TextBlock x:Name="txtPhotoPath" FontSize="12" Foreground="Gray" Margin="0,5,0,0" Text="Файл не выбран"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Background="#00FA9A" Click="btnSave_Click" Width="100"/>
            <Button x:Name="btnDelete" Content="Удалить" Background="#7FFF00" Click="btnDelete_Click" Visibility="Collapsed" Width="100"/>
            <Button x:Name="btnCancel" Content="Отмена" Background="#7FFF00" Click="btnCancel_Click" Width="100"/>
        </StackPanel>
    </Grid>
</Window>