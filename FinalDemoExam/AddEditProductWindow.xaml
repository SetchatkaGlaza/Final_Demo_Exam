<Window x:Class="FinalDemoExam.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalDemoExam"
        mc:Ignorable="d"
        Title="Добавление/редактирование товара" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        Icon="/Image/Icon.ico">

    <Grid FontFamily="Times New Roman" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавление/редактирование товара" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="11" Margin="0,0,20,0" VerticalAlignment="Top">
                    <TextBlock Text="Фото товара" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Image x:Name="imgProduct" Height="200" Width="200" Stretch="Uniform" Source="/Image/picture.png"/>
                    <Button x:Name="btnBrowse" Content="Выбрать фото" Background="#7FFF00" Click="btnBrowse_Click" Margin="0,10"/>
                </StackPanel>

                <TextBlock Grid.Row="0" Grid.Column="1" Text="Артикул:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtArticle" Grid.Row="0" Grid.Column="1" Margin="100,5,0,5" IsEnabled="False"/>

                <TextBlock Grid.Row="1" Grid.Column="1" Text="Наименование товара:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtName" Grid.Row="1" Grid.Column="1" Margin="100,5,0,5"/>

                <TextBlock Grid.Row="2" Grid.Column="1" Text="Категория:" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbCategory" Grid.Row="2" Grid.Column="1" Margin="100,5,0,5" DisplayMemberPath="name" SelectedValuePath="id"/>

                <TextBlock Grid.Row="3" Grid.Column="1" Text="Описание:" VerticalAlignment="Top" Margin="0,10,0,0"/>
                <TextBox x:Name="txtDescription" Grid.Row="3" Grid.Column="1" Margin="100,5,0,5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock Grid.Row="4" Grid.Column="1" Text="Производитель:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtManufacturer" Grid.Row="4" Grid.Column="1" Margin="100,5,0,5"/>

                <TextBlock Grid.Row="5" Grid.Column="1" Text="Поставщик:" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbSupplier" Grid.Row="5" Grid.Column="1" Margin="100,5,0,5" DisplayMemberPath="name" SelectedValuePath="id"/>

                <TextBlock Grid.Row="6" Grid.Column="1" Text="Цена:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPrice" Grid.Row="6" Grid.Column="1" Margin="100,5,0,5"/>

                <TextBlock Grid.Row="7" Grid.Column="1" Text="Единица измерения:" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbUnit" Grid.Row="7" Grid.Column="1" Margin="100,5,0,5" DisplayMemberPath="name" SelectedValuePath="id"/>

                <TextBlock Grid.Row="8" Grid.Column="1" Text="Количество на складе:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtStock" Grid.Row="8" Grid.Column="1" Margin="100,5,0,5"/>

                <TextBlock Grid.Row="9" Grid.Column="1" Text="Действующая скидка (%):" VerticalAlignment="Center"/>
                <TextBox x:Name="txtDiscount" Grid.Row="9" Grid.Column="1" Margin="100,5,0,5"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Background="#00FA9A" Click="btnSave_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Background="#7FFF00" Click="btnDelete_Click" Visibility="Collapsed"/>
            <Button x:Name="btnCancel" Content="Отмена" Background="#7FFF00" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
