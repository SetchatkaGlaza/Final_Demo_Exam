<Window x:Class="FinalDemoExam.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Добавление/редактирование заказа" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        Icon="/Image/Icon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавление/редактирование заказа" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер заказа:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtId" Grid.Row="0" Grid.Column="1" Margin="5" IsEnabled="False"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус:" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbStatus" Grid.Row="1" Grid.Column="1" Margin="5" DisplayMemberPath="name" SelectedValuePath="id"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата заказа:" VerticalAlignment="Center"/>
                <DatePicker x:Name="dpOrderDate" Grid.Row="2" Grid.Column="1" Margin="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата доставки:" VerticalAlignment="Center"/>
                <DatePicker x:Name="dpDeliveryDate" Grid.Row="3" Grid.Column="1" Margin="5"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Пункт выдачи:" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbPickupPoint" Grid.Row="4" Grid.Column="1" Margin="5" DisplayMemberPath="address" SelectedValuePath="id"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Клиент:" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbUser" Grid.Row="5" Grid.Column="1" Margin="5" DisplayMemberPath="full_name" SelectedValuePath="id"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Товары:" VerticalAlignment="Top" Margin="0,10,0,0"/>
                <DataGrid x:Name="dgOrderItems" Grid.Row="6" Grid.Column="1" Margin="5" AutoGenerateColumns="False" Height="200">
                    <DataGrid.Columns>
                        <DataGridComboBoxColumn x:Name="productColumn" Header="Товар" DisplayMemberPath="name" SelectedValuePath="article" SelectedValueBinding="{Binding product_article}"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding quantity}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Background="#00FA9A" Click="btnSave_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Background="#7FFF00" Click="btnDelete_Click" Visibility="Collapsed"/>
            <Button x:Name="btnCancel" Content="Отмена" Background="#7FFF00" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>