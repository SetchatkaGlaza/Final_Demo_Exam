<Page x:Class="DemoEcz.Pages.Vhod"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoEcz.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация" Background="#ffffff" FontFamily="Times New Roman">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="298"/>
        </Grid.RowDefinitions>

        <Image Source="C:\Users\kuchu\OneDrive\Рабочий стол\DemoEcz (2)\DemoEcz\Assets\Icon.JPG" HorizontalAlignment="Left"/>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <TextBlock Text="Авторизация" FontSize="36" Margin="0,0,0,35"/>
            <TextBlock Text="Логин"/>
            <TextBox x:Name="Login" Height="20" Width="200" Margin="0,0,0,8"/>
            <TextBlock Text="Пароль"/>
            <PasswordBox Name="Pass" Height="20" Width="200" Margin="0,0,0,16"/>

            <Button x:Name="Vhods" Content="Войти" Height="30" Width="200" Background="#00FA9A" Click="Vhod_Click" Margin="0,0,0,10"/>
            <Button x:Name="VhodGost" Content="Войти как гость" Height="30" Width="200" Background="#00FA9A" Click="VhodGost_Click" Margin="0,0,0,10"/>
        </StackPanel>

        <TextBlock Text="*Логин это ваша почта" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
    </Grid>
</Page>