<Page x:Class="DemoEcz.Pages.AddEditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Товар" Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Добавление/Редактирование товара" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Артикул:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxArticle" Height="30" Margin="0,0,0,15"/>

                    <TextBlock Text="Название:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxName" Height="30" Margin="0,0,0,15"/>

                    <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxDescription" Height="60" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <TextBlock Text="Цена:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxCost" Height="30" Margin="0,0,0,15"/>

                    <TextBlock Text="Скидка (%):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxDiscount" Height="30" Margin="0,0,0,15"/>

                    <TextBlock Text="Количество на складе:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxQuantity" Height="30" Margin="0,0,0,15"/>

                    <TextBlock Text="Единица измерения:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxEdIzm" Height="30" Margin="0,0,0,15" Text="шт"/>

                    <TextBlock Text="Поставщик:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox Name="CBoxPostav" Height="30" Margin="0,0,0,15">
                        <ComboBoxItem Content="Kari"/>
                        <ComboBoxItem Content="Обувь для вас"/>
                        <ComboBoxItem Content="Zenden"/>
                        <ComboBoxItem Content="Спортмастер"/>
                    </ComboBox>

                    <TextBlock Text="Производитель:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxProizw" Height="30" Margin="0,0,0,15"/>

                    <TextBlock Text="Категория (ID):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Name="TBoxKat" Height="30" Margin="0,0,0,15" Text="1"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Фото товара" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" 
                            Height="150" Width="150" HorizontalAlignment="Center" Background="#F5F5F5">
                        <Image Name="ImageProduct" Stretch="Uniform" Margin="5"/>
                    </Border>
                    <Button Name="BtnSelectImage" Click="BtnSelectImage_Click" Content="Выбрать фото" 
                            Height="35" Margin="0,10,0,0" Background="#4CAF50" Foreground="White" 
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <Button Name="BtnSave" Click="BtnSave_Click" Content="Сохранить" 
                        Width="120" Height="40" Margin="5" Background="#2196F3" 
                        Foreground="White" FontSize="14" Cursor="Hand"/>
                <Button Name="BtnCancel" Click="BtnCancel_Click" Content="Отмена" 
                        Width="120" Height="40" Margin="5" Background="#f44336" 
                        Foreground="White" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>