<Page x:Class="DemoEcz.Pages.Admin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoEcz.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Каталог" Background="#ffffff" FontFamily="Times New Roman" Loaded="PageLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="62*"/>
            <RowDefinition Height="349*"/>
            <RowDefinition Height="39*"/>
        </Grid.RowDefinitions>

        <Image Source="C:\Users\kuchu\OneDrive\Рабочий стол\DemoEcz (2)\DemoEcz\Assets\Icon.JPG" HorizontalAlignment="Left"></Image>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Height="20">
            <TextBlock Name="FIO" Text="заТЫЧКА" FontSize="10"></TextBlock>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Center">

            <StackPanel Orientation="Vertical" Name="Filtr">
                <TextBlock Text="Фильтрация по скидке"></TextBlock>
                <ComboBox Name="Filtrs" Width="140" SelectionChanged="FiltrsSelectionChanged">
                    <ComboBoxItem Content="Все диапазоны"></ComboBoxItem>
                    <ComboBoxItem Content="0-12.99%"></ComboBoxItem>
                    <ComboBoxItem Content="13-16.99%"></ComboBoxItem>
                    <ComboBoxItem Content="17% и более"></ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="20,0" Name="Sort">
                <TextBlock Text="Сортировка"></TextBlock>
                <ComboBox Width="140" Name="Sorts" SelectionChanged="SortsSelectionChanged">
                    <ComboBoxItem Content="Без"></ComboBoxItem>
                    <ComboBoxItem Content="по возрастанию (остаток)"></ComboBoxItem>
                    <ComboBoxItem Content="по убыванию (остаток)"></ComboBoxItem>
                    <ComboBoxItem Content="по возрастанию (цена)"></ComboBoxItem>
                    <ComboBoxItem Content="по убыванию (цена)"></ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Поиск"></TextBlock>
                <TextBox x:Name="Poisk" Width="140" TextChanged="Text_TextChanged"></TextBox>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Width="700">
            <ItemsControl x:Name="TovarVivod">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Border Grid.Row="1" BorderBrush="#0000" Background="{Binding Zvet}" Name="Salle" Width="490"
                                    Height="120" Margin="20" MouseLeftButtonUp="TovarVivodMouseLeftButtonUp">
                                
                                <StackPanel Orientation="Horizontal" Margin="10,5,4,3">
                                    
                                    <StackPanel Orientation="Vertical" Width="112" Margin="0,0,14,0">
                                        <Image Source="{Binding FotoItog}" Width="100" Height="100"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Vertical" Width="250">
                                        <StackPanel Orientation="Horizontal" >
                                            <TextBlock  Text="{Binding Kat1.kat1}" FontSize="16" FontWeight="Bold"></TextBlock>
                                            <TextBlock  Text=" | " FontSize="16" FontWeight="Bold"></TextBlock>
                                            <TextBlock  Text="{Binding name}" FontSize="16" FontWeight="Bold"></TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" >
                                            <TextBlock FontSize="13" Text="Описанике : "/>
                                            <TextBlock  Text="{Binding opisanie}" FontSize="13"></TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" >
                                            <TextBlock FontSize="13"  Text="Производитель : "/>
                                            <TextBlock  Text="{Binding proizw}" FontSize="13"></TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" >
                                            <TextBlock FontSize="13" Text="Поставщик : "/>
                                            <TextBlock  Text="{Binding postaw}" FontSize="13"></TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" >
                                            <TextBlock FontSize="13" Text="Цена : "/>
                                            <TextBlock   Text="{Binding cena}"  TextDecorations="{Binding Strikethrough}" Foreground="{Binding TextColor}" FontSize="13" Margin="0,0,5,0"></TextBlock>
                                            <TextBlock  Text="{Binding NovCena}" Visibility="{Binding Visibility}" FontSize="13"></TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" >
                                            <TextBlock  Text="Еденицы измерения : " FontSize="13" ></TextBlock>
                                            <TextBlock  Text="{Binding ed_izm}" FontSize="13"></TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" >
                                            <TextBlock  Text="Количество на складе : " FontSize="13" ></TextBlock>
                                            <TextBlock  Text="{Binding ostatok}" FontSize="13"></TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Width="100">
                                        <TextBlock Text="{Binding skidka}" Margin="0,45" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Button x:Name="Uadl" Content="Удалить" Height="30" Width="100" Background="#00FA9A" HorizontalAlignment="Left" 
                                        Click="UadlClick" Tag="{Binding}"/>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <Button x:Name="Vhods" Content="Выйти" Height="30" Background="#00FA9A"
                Grid.Row="2" Width="200" HorizontalAlignment="Left" Click="Vhod_Click"></Button>
        
        <TextBlock Text="Для редактирования нажмите на товар" Grid.Row="2" HorizontalAlignment="Center"></TextBlock>
        
        <Button x:Name="Dob" Content="Добавить" Height="30" Background="#00FA9A"
                    Grid.Row="2" Width="200" HorizontalAlignment="Right" Click="Dob_Click"></Button>
    </Grid>
</Page>